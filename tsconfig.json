{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "lib": ["ES2022", "DOM"],
    "types": ["node"]
  },
  "include": [
    "src/game/**/*.ts",
    "src/game/**/*.js",
    "src/gameplay/**/*.ts",
    "src/gameplay/**/*.js",
    "src/core/**/*.ts",
    "src/core/**/*.js"
  ],
  "exclude": ["node_modules", "dist"]
}
